        <mxCell id="wqfIOTe3UAbFo0YZ9cAL-10" value="&lt;b&gt;Subscriber Callbacks&lt;/b&gt;&lt;br&gt;• path_callback()&lt;br&gt;• pose_callback()&lt;br&gt;• dynamics_callback()&lt;br&gt;• mission_callback()&lt;br&gt;• state_callback()&lt;br&gt;• lap_callback()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#FBC02D;align=left;spacingLeft=8;fontSize=11;" parent="wqfIOTe3UAbFo0YZ9cAL-9" vertex="1">
