        </mxCell>
        <mxCell id="wqfIOTe3UAbFo0YZ9cAL-18" value="Pursuit_Algorithm Polymorphic Implementations (Configured at compilation via include macro)" style="swimlane;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9C27B0;fontStyle=1;startSize=25;" parent="wqfIOTe3UAbFo0YZ9cAL-1" vertex="1">
          <mxGeometry x="250" y="530" width="770" height="340" as="geometry" />
        </mxCell>
        <mxCell id="wqfIOTe3UAbFo0YZ9cAL-19" value="&lt;b&gt;VehicleModel&lt;/b&gt;&lt;br&gt;[dry_model.hpp]&lt;br&gt;Grip Coeff: 0.8" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9C27B0;fontSize=11;" parent="wqfIOTe3UAbFo0YZ9cAL-18" vertex="1">
          <mxGeometry x="20" y="40" width="120" height="55" as="geometry" />
        </mxCell>
        <mxCell id="wqfIOTe3UAbFo0YZ9cAL-20" value="&lt;b&gt;PID_Controller&lt;/b&gt;&lt;br&gt;Discrete anti-windup&lt;br&gt;Speed tracking loop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9C27B0;fontSize=11;" parent="wqfIOTe3UAbFo0YZ9cAL-18" vertex="1">
          <mxGeometry x="20" y="110" width="120" height="55" as="geometry" />
        </mxCell>
        <mxCell id="wqfIOTe3UAbFo0YZ9cAL-21" value="&lt;b&gt;Low-Pass Filter&lt;/b&gt;&lt;br&gt;Steering smoothing&lt;br&gt;α = dt / (τ + dt)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9C27B0;fontSize=11;" parent="wqfIOTe3UAbFo0YZ9cAL-18" vertex="1">
          <mxGeometry x="20" y="175" width="120" height="45" as="geometry" />
        </mxCell>
        <mxCell id="wqfIOTe3UAbFo0YZ9cAL-22" value="&lt;b&gt;1. Pure Pursuit&lt;/b&gt;&lt;br&gt;[pure_pursuit.cpp]&lt;br&gt;• Base coordinate frames transformation&lt;br&gt;• Fixed lookup lookup window calculation&lt;br&gt;• Geometric target angle extraction&lt;br&gt;• Target speed set directly via raw curvature" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#BA68C8;align=left;spacingLeft=8;fontSize=11;" parent="wqfIOTe3UAbFo0YZ9cAL-18" vertex="1">
          <mxGeometry x="160" y="40" width="280" height="130" as="geometry" />
        </mxCell>
        <mxCell id="wqfIOTe3UAbFo0YZ9cAL-23" value="&lt;b&gt;2. LP Pursuit (Low-Pass)&lt;/b&gt;&lt;br&gt;[lp_pursuit.cpp]&lt;br&gt;• Inherits geometric Pure Pursuit architecture&lt;br&gt;• Integrates Low-Pass filtering layer onto output wheel angle&lt;br&gt;• Clamps high-frequency steering chatter &amp; actuator noise&lt;br&gt;• RPM delta limitation applied per loop step" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#BA68C8;align=left;spacingLeft=8;fontSize=11;" parent="wqfIOTe3UAbFo0YZ9cAL-18" vertex="1">
          <mxGeometry x="160" y="190" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="wqfIOTe3UAbFo0YZ9cAL-24" value="&lt;b&gt;3. ACC Pursuit (Acceleration Control)&lt;/b&gt;&lt;br&gt;[acc_pursuit.cpp]&lt;br&gt;• dynamic lookahead based on speed &amp; curvature preview&lt;br&gt;• Computes path preview average absolute curvature profiles&lt;br&gt;• Drives longitudinal velocity setpoint into a discrete PID loop&lt;br&gt;• Generates direct raw acceleration command (&#39;acc_cmd&#39;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#BA68C8;align=left;spacingLeft=8;fontSize=11;" parent="wqfIOTe3UAbFo0YZ9cAL-18" vertex="1">
          <mxGeometry x="460" y="40" width="295" height="130" as="geometry" />
        </mxCell>
        <mxCell id="wqfIOTe3UAbFo0YZ9cAL-25" value="&lt;b&gt;4. FF Pursuit (Feed-Forward Steering)&lt;/b&gt;&lt;br&gt;[ff_pursuit.cpp]&lt;br&gt;• Incorporates underlying ACC speed controller execution framework&lt;br&gt;• Evaluates path spline curvature vectors explicitly&lt;br&gt;• Direct predictive model steering calculations: δ_ff = atan(L * κ)&lt;br&gt;• Blends raw geometric pursuit angle feedback with 50% feed-forward" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#BA68C8;align=left;spacingLeft=8;fontSize=11;" parent="wqfIOTe3UAbFo0YZ9cAL-18" vertex="1">
          <mxGeometry x="460" y="190" width="295" height="140" as="geometry" />
        </mxCell>
