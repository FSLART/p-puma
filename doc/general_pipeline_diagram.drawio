        <mxCell id="wqfIOTe3UAbFo0YZ9cAL-11" value="&lt;b&gt;Runtime Param Updates&lt;/b&gt;&lt;br&gt;parametersCallback()&lt;br&gt;Updates gains/speeds live" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#FBC02D;fontSize=11;" parent="wqfIOTe3UAbFo0YZ9cAL-9" vertex="1">
