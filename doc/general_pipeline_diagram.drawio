        </mxCell>
        <mxCell id="wqfIOTe3UAbFo0YZ9cAL-12" value="&lt;b&gt;Control Timer Loop&lt;/b&gt;&lt;br&gt;Runs at 50 Hz (FREQUENCY)&lt;br&gt;Triggers dispatchDynamicsCMD()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3CD;strokeColor=#FFC107;fontSize=11;fontStyle=1" parent="wqfIOTe3UAbFo0YZ9cAL-9" vertex="1">
