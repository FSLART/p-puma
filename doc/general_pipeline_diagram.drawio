        </mxCell>
        <mxCell id="wqfIOTe3UAbFo0YZ9cAL-13" value="&lt;b&gt;Safety &amp; State Monitoring&lt;/b&gt;&lt;br&gt;• checkTimeStamp() [3s Delay]&lt;br&gt;• cleanUp() on EMERGENCY&lt;br&gt;• Zero commands on FINISH" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#EF5350;align=left;spacingLeft=8;fontSize=11;" parent="wqfIOTe3UAbFo0YZ9cAL-9" vertex="1">
